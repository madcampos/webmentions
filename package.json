{
	"name": "webmentions",
	"private": true,
	"version": "5.0.0",
	"license": "MIT",
	"type": "module",
	"engines": {
		"node": ">=24.13.0",
		"pnpm": ">=10.26.2"
	},
	"scripts": {
		"bootstrap:types": "wrangler types src/env.d.ts",
		"bootstrap": "pnpm run bootstrap:types",

		"start": "wrangler dev src/index.ts",

		"format": "dprint fmt",
		"typecheck": "tsc --noEmit",
		"lint:js": "oxlint --fix",
		"lint": "pnpm run typecheck && pnpm run lint:js",

		"db:migrations:local": "wrangler d1 migrations apply webmentions-db",
		"db:migrations:remote": "wrangler d1 migrations apply webmentions-db --remote",
		"deploy": "wrangler deploy --minify --env=\"\"",

		"test": "vitest"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.16.16",
		"@types/node": "^25.9.2",
		"@vitest/coverage-istanbul": "^4.1.8",
		"dprint": "^0.54.0",
		"oxlint": "^1.68.0",
		"oxlint-tsgolint": "^0.23.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.8",
		"wrangler": "^4.100.0"
	},
	"dependencies": {
		"node-html-parser": "^7.1.0"
	}
}
